  },
  "homepage": "https://github.com/HageC/job-manager#readme",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "concurrently": "^7.4.0",
    "dotenv": "^16.0.3",
    "express": "^4.18.1",
    "jsonwebtoken": "^8.5.1",
    "mongoose": "^6.6.5",
    "nodemon": "^2.0.20",
    "validator": "^13.7.0"
  }
}
